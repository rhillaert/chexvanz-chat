# ── Anthropic (Claude AI) ─────────────────────────────────────────
# Get this at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Twilio (SMS alerts) ───────────────────────────────────────────
# Get these at twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # the Twilio phone number you buy

# ── Your phone (for SMS alerts) ──────────────────────────────────
OWNER_PHONE=+17035990515

# ── Email (for lead notifications) ───────────────────────────────
# Use a Gmail address with an App Password (not your main password)
# Instructions: myaccount.google.com → Security → App Passwords
EMAIL_FROM=yournotifications@gmail.com
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Server ────────────────────────────────────────────────────────
PORT=3000
